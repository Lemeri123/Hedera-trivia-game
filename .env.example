# ─────────────────────────────────────────────────────
# Hash Gordon's Blockchain Bonanza — environment variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────

# Groq API key — free at https://console.groq.com
# Used for testing. Swap to OPENAI_API_KEY for production.
GROQ_API_KEY=gsk_...

# Your Hedera operator account (the player's wallet).
# Obtain testnet credentials at: https://portal.hedera.com/
# HEDERA_PRIVATE_KEY must be in DER-encoded format (starts with 302...).
HEDERA_ACCOUNT_ID=0.0.XXXXX
HEDERA_PRIVATE_KEY=your-private-key-here

# Hedera network: testnet (default) | mainnet | previewnet
HEDERA_NETWORK=testnet

# The prize pool account that collects entry fees and funds payouts.
# Create a second testnet account at https://portal.hedera.com/ and fund it
# with enough HBAR to cover payouts (e.g. 50 HBAR for ~25 rounds).
PRIZE_POOL_ACCOUNT_ID=0.0.YYYYY
PRIZE_POOL_PRIVATE_KEY=<DER private key for 0.0.8895143>


# Optional: customize the game economics (defaults shown)
ENTRY_FEE_HBAR=1
PAYOUT_MULTIPLIER=2
